/* pages/teacher/schedule.wxss */
.schedule-container {
  min-height: 100vh;
  background: #f8f9fa;
  display: flex;
  flex-direction: column;
}

.date-header {
  background: #ffffff;
  padding: 30rpx 40rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-bottom: 2rpx solid #f0f0f0;
}

.date-nav {
  display: flex;
  align-items: center;
  gap: 40rpx;
}

.nav-btn {
  font-size: 36rpx;
  color: #1890ff;
  font-weight: bold;
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 30rpx;
  background: #f0f8ff;
}

.current-date {
  font-size: 32rpx;
  font-weight: 500;
  color: #333333;
}

.today-btn {
  font-size: 26rpx;
  color: #1890ff;
  padding: 12rpx 24rpx;
  border: 2rpx solid #1890ff;
  border-radius: 20rpx;
}

.time-header {
  background: #ffffff;
  display: flex;
  border-bottom: 2rpx solid #f0f0f0;
}

.time-label {
  width: 120rpx;
  background: #fafafa;
  font-weight: 500;
}

.day-cells {
  flex: 1;
  display: flex;
}

.day-cell {
  flex: 1;
  padding: 20rpx;
  text-align: center;
  border-left: 2rpx solid #f0f0f0;
}

.day-cell.today {
  background: #e6f7ff;
  color: #1890ff;
}

.day-name {
  display: block;
  font-size: 24rpx;
  color: #666666;
  margin-bottom: 8rpx;
}

.day-cell.today .day-name {
  color: #1890ff;
}

.day-date {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: #333333;
}

.day-cell.today .day-date {
  color: #1890ff;
}

.schedule-content {
  flex: 1;
  height: 60vh;
}

.time-slots {
  background: #ffffff;
}

.time-row {
  display: flex;
  border-bottom: 1rpx solid #f0f0f0;
  min-height: 120rpx;
}

.time-cell {
  width: 120rpx;
  padding: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: #666666;
  background: #fafafa;
}

.day-slots {
  flex: 1;
  display: flex;
}

.day-slot {
  flex: 1;
  border-left: 1rpx solid #f0f0f0;
  padding: 8rpx;
}

.schedule-item {
  height: 100%;
  border-radius: 8rpx;
  padding: 12rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  text-align: center;
  font-size: 22rpx;
  transition: all 0.3s ease;
}

.schedule-item:active {
  opacity: 0.8;
  transform: scale(0.95);
}

.schedule-item.available {
  background: #f6ffed;
  border: 2rpx solid #b7eb8f;
  color: #52c41a;
}

.schedule-item.booked {
  background: #fff7e6;
  border: 2rpx solid #ffd591;
  color: #fa8c16;
}

.schedule-item.completed {
  background: #f6ffed;
  border: 2rpx solid #b7eb8f;
  color: #52c41a;
}

.schedule-item.cancelled {
  background: #f5f5f5;
  border: 2rpx solid #d9d9d9;
  color: #bfbfbf;
}

.student-name {
  font-weight: 500;
  margin-bottom: 4rpx;
}

.schedule-status {
  font-size: 20rpx;
}

.stats-footer {
  background: #ffffff;
  padding: 30rpx 40rpx;
  display: flex;
  justify-content: space-around;
  border-top: 2rpx solid #f0f0f0;
}

.stat-item {
  text-align: center;
}

.stat-value {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #1890ff;
  margin-bottom: 8rpx;
}

.stat-label {
  display: block;
  font-size: 24rpx;
  color: #666666;
}