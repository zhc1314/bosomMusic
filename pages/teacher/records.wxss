/* pages/teacher/records.wxss */
.records-container {
  min-height: 100vh;
  background: #f8f9fa;
  display: flex;
  flex-direction: column;
}

.filter-bar {
  background: #ffffff;
  padding: 30rpx 40rpx;
  display: flex;
  gap: 20rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.filter-picker {
  flex: 1;
}

.picker-label {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 24rpx;
  background: #fafafa;
  border: 2rpx solid #e8e8e8;
  border-radius: 12rpx;
  font-size: 26rpx;
  color: #333333;
}

.picker-text {
  flex: 1;
}

.picker-arrow {
  color: #999999;
  font-size: 20rpx;
}

.records-list {
  flex: 1;
  height: 70vh;
  padding: 30rpx 40rpx;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 400rpx;
  text-align: center;
}

.empty-icon {
  width: 120rpx;
  height: 120rpx;
  margin-bottom: 30rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 28rpx;
  color: #999999;
  margin-bottom: 16rpx;
}

.empty-desc {
  font-size: 24rpx;
  color: #cccccc;
}

.records {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.record-item {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.record-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.student-name {
  font-size: 32rpx;
  font-weight: 500;
  color: #333333;
}

.record-status {
  font-size: 24rpx;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
}

.record-status.booked {
  background: #fff7e6;
  color: #fa8c16;
}

.record-status.completed {
  background: #f6ffed;
  color: #52c41a;
}

.record-status.cancelled {
  background: #f5f5f5;
  color: #bfbfbf;
}

.record-info {
  margin-bottom: 20rpx;
}

.info-item {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.info-label {
  font-size: 26rpx;
  color: #666666;
  min-width: 120rpx;
}

.info-value {
  font-size: 26rpx;
  color: #333333;
  flex: 1;
}

.rating-stars {
  display: flex;
  gap: 8rpx;
}

.star {
  font-size: 24rpx;
  color: #cccccc;
}

.star.active {
  color: #ffc53d;
}

.record-actions {
  border-top: 1rpx solid #f0f0f0;
  padding-top: 20rpx;
}

.evaluate-btn {
  width: 100%;
  height: 64rpx;
  background: linear-gradient(135deg, #1890ff 0%, #096dd9 100%);
  color: #ffffff;
  border: none;
  border-radius: 12rpx;
  font-size: 26rpx;
}

.evaluate-btn:active {
  opacity: 0.8;
}

/* 模态框样式 */
.modal {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.5);
  display: none;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal.show {
  display: flex;
}

.modal-content {
  background: #ffffff;
  border-radius: 20rpx;
  width: 80%;
  max-width: 600rpx;
  max-height: 80vh;
  overflow: hidden;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 40rpx 40rpx 20rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 500;
  color: #333333;
}

.modal-close {
  font-size: 40rpx;
  color: #999999;
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-body {
  padding: 40rpx;
}

.evaluation-info {
  margin-bottom: 40rpx;
}

.eval-student, .eval-time {
  display: block;
  font-size: 26rpx;
  color: #666666;
  margin-bottom: 8rpx;
}

.rating-section {
  display: flex;
  align-items: center;
  margin-bottom: 40rpx;
}

.rating-label {
  font-size: 26rpx;
  color: #333333;
  min-width: 120rpx;
}

.rating-input {
  display: flex;
  gap: 16rpx;
}

.star-input {
  font-size: 36rpx;
  color: #cccccc;
  transition: all 0.3s ease;
}

.star-input.active {
  color: #ffc53d;
}

.evaluation-section {
  position: relative;
}

.eval-label {
  display: block;
  font-size: 26rpx;
  color: #333333;
  margin-bottom: 16rpx;
}

.eval-textarea {
  width: 100%;
  height: 200rpx;
  border: 2rpx solid #e8e8e8;
  border-radius: 12rpx;
  padding: 20rpx;
  font-size: 26rpx;
  background: #fafafa;
  box-sizing: border-box;
}

.char-count {
  position: absolute;
  right: 20rpx;
  bottom: 20rpx;
  font-size: 22rpx;
  color: #999999;
}

.modal-footer {
  display: flex;
  gap: 20rpx;
  padding: 20rpx 40rpx 40rpx;
}

.btn-cancel, .btn-confirm {
  flex: 1;
  height: 80rpx;
  border: none;
  border-radius: 12rpx;
  font-size: 28rpx;
}

.btn-cancel {
  background: #f5f5f5;
  color: #666666;
}

.btn-confirm {
  background: linear-gradient(135deg, #1890ff 0%, #096dd9 100%);
  color: #ffffff;
}