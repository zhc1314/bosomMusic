/* pages/index/index.wxss */
.index-container {
  min-height: 100vh;
  background: #f8f9fa;
  padding-bottom: 40rpx;
}

.banner-swiper {
  height: 400rpx;
  position: relative;
}

.banner-image {
  width: 100%;
  height: 100%;
}

.banner-content {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: linear-gradient(transparent, rgba(0, 0, 0, 0.7));
  padding: 40rpx;
  color: #ffffff;
}

.banner-title {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 8rpx;
}

.banner-desc {
  display: block;
  font-size: 26rpx;
  opacity: 0.9;
}

.user-info {
  background: #ffffff;
  margin: 20rpx 40rpx;
  border-radius: 20rpx;
  padding: 40rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.user-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  background: #f0f8ff;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 30rpx;
}

.avatar {
  width: 60rpx;
  height: 60rpx;
}

.user-details {
  flex: 1;
}

.user-name {
  display: block;
  font-size: 32rpx;
  font-weight: 500;
  color: #333333;
  margin-bottom: 8rpx;
}

.user-role {
  display: block;
  font-size: 26rpx;
  color: #666666;
}

.user-stats {
  text-align: center;
}

.login-prompt {
  background: #ffffff;
  margin: 20rpx 40rpx;
  border-radius: 20rpx;
  padding: 60rpx 40rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
  text-align: center;
}

.prompt-content {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.prompt-icon {
  width: 120rpx;
  height: 120rpx;
  margin-bottom: 30rpx;
  opacity: 0.7;
}

.prompt-title {
  font-size: 32rpx;
  font-weight: 500;
  color: #333333;
  margin-bottom: 16rpx;
}

.prompt-desc {
  font-size: 26rpx;
  color: #666666;
  margin-bottom: 40rpx;
  line-height: 1.5;
}

.prompt-login-btn {
  width: 200rpx;
  height: 80rpx;
  background: linear-gradient(135deg, #1890ff 0%, #096dd9 100%);
  color: #ffffff;
  border: none;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: 500;
}

.prompt-login-btn:active {
  opacity: 0.8;
}

.stat-value {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  color: #1890ff;
  margin-bottom: 8rpx;
}

.stat-label {
  display: block;
  font-size: 24rpx;
  color: #999999;
}

.function-panel {
  background: #ffffff;
  margin: 20rpx 40rpx;
  border-radius: 20rpx;
  padding: 40rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.panel-title {
  display: block;
  font-size: 32rpx;
  font-weight: 500;
  color: #333333;
  margin-bottom: 30rpx;
}

.function-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 30rpx;
}

.function-item {
  text-align: center;
  padding: 30rpx 20rpx;
  border-radius: 16rpx;
  background: #fafafa;
  transition: all 0.3s ease;
}

.function-item:active {
  background: #f0f0f0;
  transform: scale(0.95);
}

.function-icon {
  font-size: 48rpx;
  margin-bottom: 16rpx;
}

.function-name {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: #333333;
  margin-bottom: 8rpx;
}

.function-desc {
  display: block;
  font-size: 22rpx;
  color: #999999;
}

.today-reminder {
  background: #ffffff;
  margin: 20rpx 40rpx;
  border-radius: 20rpx;
  padding: 40rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.reminder-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.reminder-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #333333;
}

.reminder-count {
  font-size: 26rpx;
  color: #1890ff;
  font-weight: 500;
}

.lesson-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.lesson-item {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background: #f8f9fa;
  border-radius: 12rpx;
}

.lesson-time {
  font-size: 26rpx;
  font-weight: 500;
  color: #333333;
  min-width: 200rpx;
}

.lesson-info {
  flex: 1;
  font-size: 26rpx;
  color: #666666;
}

.lesson-status {
  font-size: 24rpx;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
}

.lesson-status.booked {
  background: #fff7e6;
  color: #fa8c16;
}

.lesson-status.completed {
  background: #f6ffed;
  color: #52c41a;
}

.footer {
  text-align: center;
  margin-top: 60rpx;
}

.footer-text {
  font-size: 24rpx;
  color: #999999;
}
