/* pages/role/role.wxss */
.role-container {
  min-height: 100vh;
  background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
  padding: 60rpx 40rpx;
}

.header {
  text-align: center;
  margin-bottom: 80rpx;
}

.title {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 16rpx;
}

.subtitle {
  display: block;
  font-size: 28rpx;
  color: #666666;
}

.role-cards {
  display: flex;
  flex-direction: column;
  gap: 40rpx;
}

.role-card {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 60rpx 40rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.08);
  transition: all 0.3s ease;
  position: relative;
  overflow: hidden;
}

.role-card:active {
  transform: translateY(-4rpx);
  box-shadow: 0 12rpx 40rpx rgba(0, 0, 0, 0.12);
}

.teacher-card {
  border-left: 8rpx solid #1890ff;
}

.student-card {
  border-left: 8rpx solid #52c41a;
}

.card-icon {
  width: 120rpx;
  height: 120rpx;
  background: linear-gradient(135deg, #1890ff 0%, #096dd9 100%);
  border-radius: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 30rpx;
}

.student-card .card-icon {
  background: linear-gradient(135deg, #52c41a 0%, #389e0d 100%);
}

.icon {
  width: 60rpx;
  height: 60rpx;
}

.role-title {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 16rpx;
}

.role-desc {
  display: block;
  font-size: 26rpx;
  color: #666666;
  margin-bottom: 30rpx;
  line-height: 1.5;
}

.features {
  margin-bottom: 40rpx;
}

.feature {
  display: block;
  font-size: 24rpx;
  color: #888888;
  margin-bottom: 8rpx;
}

.select-btn {
  width: 100%;
  height: 80rpx;
  background: linear-gradient(135deg, #1890ff 0%, #096dd9 100%);
  color: #ffffff;
  border: none;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s ease;
}

.student-card .select-btn {
  background: linear-gradient(135deg, #52c41a 0%, #389e0d 100%);
}

.select-btn:active {
  opacity: 0.8;
  transform: scale(0.98);
}

.tip {
  text-align: center;
  margin-top: 60rpx;
}

.tip-text {
  font-size: 24rpx;
  color: #999999;
}